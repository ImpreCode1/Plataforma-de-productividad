erDiagram

    ORGANIZATION_UNIT {
        uuid id PK
        string name
        string type
        uuid parent_id FK
        timestamp created_at
    }

    POSITION {
        uuid id PK
        string name
        uuid organization_unit_id FK
        timestamp created_at
    }

    USER {
        uuid id PK
        string external_auth_id
        string name
        string email
        uuid position_id FK
        uuid leader_id FK
        boolean is_active
        timestamp created_at
        timestamp updated_at
    }

    ROLE {
        uuid id PK
        string name
        string description
    }

    USER_ROLE {
        uuid user_id FK
        uuid role_id FK
    }

    INDICATOR {
        uuid id PK
        string name
        string formula_text
        string frequency
        boolean is_active
        timestamp created_at
    }

    POSITION_INDICATOR {
        uuid id PK
        uuid position_id FK
        uuid indicator_id FK
        int year
        decimal target_value
        decimal weight
        timestamp created_at
    }

    INDICATOR_TRACKING {
        uuid id PK
        uuid user_id FK
        uuid position_indicator_id FK
        int month
        decimal achieved_value
        decimal achievement_percentage
        decimal weighted_score
        boolean target_met
        string status
        timestamp created_at
        UNIQUE user_id, position_indicator_id, month
    }

    ACTION_PLAN {
        uuid id PK
        uuid indicator_tracking_id FK UNIQUE
        text reason_not_met
        text action_plan
        uuid created_by FK
        timestamp created_at
    }

    EVIDENCE {
        uuid id PK
        uuid indicator_tracking_id FK
        string file_path
        uuid uploaded_by FK
        timestamp uploaded_at
    }


    ORGANIZATION_UNIT ||--o{ ORGANIZATION_UNIT : parent_child
    ORGANIZATION_UNIT ||--o{ POSITION : contains
    POSITION ||--o{ USER : assigned
    USER ||--o{ USER : leads

    USER ||--o{ USER_ROLE : has
    ROLE ||--o{ USER_ROLE : assigned

    POSITION ||--o{ POSITION_INDICATOR : configures
    INDICATOR ||--o{ POSITION_INDICATOR : applies

    USER ||--o{ INDICATOR_TRACKING : records
    POSITION_INDICATOR ||--o{ INDICATOR_TRACKING : tracks

    INDICATOR_TRACKING ||--|| ACTION_PLAN : generates
    INDICATOR_TRACKING ||--o{ EVIDENCE : supports